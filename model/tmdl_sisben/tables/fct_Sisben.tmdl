	measure Color_Tarjeta =
			
			IF (
			    ISFILTERED ( fct_Sisben[anio] ),
			    "#B0942B",   -- color cuando hay filtro
			    "#E0E0E0"    -- color cuando no hay filtro
			)

		displayFolder: "UX"

		lineageTag: d1e43ebb-9b62-405d-89b6-567a93fd7e9b

	measure Personas_Pobreza = ```
			
			CALCULATE(
			    [Personas],
			    fct_Sisben[grupo_sisben] IN {"A","B"}
			)
			
			```
		formatString: 0.00

		displayFolder: "IPM"

		lineageTag: 89574834-9ac1-4c49-be18-6486762fbea0

	measure Pct_Personas_Pobreza =
			
			VAR Pobres = [Personas_Pobreza]
			VAR TotalP = [Personas]
			RETURN
			IF(
			    TotalP > 0,
			    DIVIDE(Pobres, TotalP),
			    0
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %

		displayFolder: "IPM"

		lineageTag: a5c28b61-cce2-4dce-b7fe-2a5ddc879eef

	measure IPM_Subtexto = ```
			
			FORMAT([Personas IPM] / 1000000, "#,##0.0") & 
			" millones de personas"
			
			```

		displayFolder: "IPM"

		lineageTag: bd13778e-4453-4081-85ad-0c53d2792abc

	measure Ranking_IPM = ```
			
			RANKX(
			    ALL(dim_municipios[Municipio]),
			    [Porcentaje_IPM],
