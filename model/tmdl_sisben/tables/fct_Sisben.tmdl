	measure Max_Problema_Vivienda =
			
			MAXX(
			    {
			        [Pct_Sin_Energia],
			        [Pct_Sin_Gas],
			        [Pct_Sin_Acueducto],
			        [Pct_Sin_Alcantarillado],
			        [Pct_Sin_Recoleccion]
			    },
			    [Value]
			)
		formatString: 0.00\ %;-0.00\ %;0.00\ %

		displayFolder: "Vivienda"

		lineageTag: 18471d75-8239-4fd8-ab90-7ed7bf583c59

	measure Problema_Dominante =
			
			VAR energia = [Pct_Sin_Energia]
			VAR gas = [Pct_Sin_Gas]
			VAR agua = [Pct_Sin_Acueducto]
			VAR alc = [Pct_Sin_Alcantarillado]
			VAR rec = [Pct_Sin_Recoleccion]
			
			VAR maximo =
			MAXX(
			    {energia, gas, agua, alc, rec},
			    [Value]
			)
			
			RETURN
			SWITCH(
			TRUE(),
			maximo = energia, "Sin energía",
			maximo = gas, "Sin gas",
			maximo = agua, "Sin acueducto",
			maximo = alc, "Sin alcantarillado",
			maximo = rec, "Sin recolección"
			)

		displayFolder: "Vivienda"

		lineageTag: 0053d59f-de8d-424e-b199-aa337ce47a08

