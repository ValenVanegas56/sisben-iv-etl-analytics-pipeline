	measure Municipio_Mayor_Volumen = ```
			
			VAR TablaRanking =
			    ADDCOLUMNS(
			        ALL(dim_municipios),
			        "Volumen", [Personas IPM]
			    )
			VAR Top1 =
			    TOPN(1, TablaRanking, [Volumen], DESC)
			RETURN
			    MAXX(Top1, dim_municipios[Municipio])
			
			```

		displayFolder: "IPM"

		lineageTag: 0ad30232-8b32-4c26-97a2-8eda49c748cc

