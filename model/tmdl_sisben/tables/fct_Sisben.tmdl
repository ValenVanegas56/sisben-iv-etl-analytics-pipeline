	measure Participacion_IPM_Subregion3 = ```
			
			VAR TotalSubregion =
			    CALCULATE(
			        [Personas IPM],
			        REMOVEFILTERS(fct_Sisben[grupo_sisben]),
			        REMOVEFILTERS(dim_municipios[Municipio]),
			        VALUES(dim_municipios[Subregion])
			    )
			RETURN
			DIVIDE([Personas IPM], TotalSubregion)
			
