	measure IPM_Acumulado =
			VAR CurrentIPM = [Personas IPM]
			RETURN
			    IF (
			        NOT ISBLANK(CurrentIPM),
			        CALCULATE(
			            [Personas IPM],
			            FILTER(
			                ALL(dim_municipios),
			                [Personas IPM] >= CurrentIPM
			            )
			        )
			    )
		formatString: 0

		displayFolder: "IPM"

		lineageTag: 32cdc41f-08f0-4700-9441-bdc139e44fb9

	measure IPM_Acumulado_% = ```
			
			DIVIDE(
			    [IPM_Acumulado],
			    CALCULATE([Personas IPM], ALL(dim_municipios))
			)
			
			```

		displayFolder: "IPM"

		lineageTag: c0dbe01e-3b4d-4126-a26c-5e148a6b2c50

		annotation PBI_FormatHint = {"isGeneralNumber":true}

