	measure Incidencia =
			
			DIVIDE([Personas IPM], [Personas])

		displayFolder: "IPM"

		lineageTag: acb7aa1c-e5d2-41f7-8484-22d03f7aed11

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Subregion_Mayor_Incidencia = ```
			
			VAR TablaResumen =
			    ADDCOLUMNS(
			        VALUES('dim_municipios'[Subregion]),
			        "Inc", [Incidencia]
			    )
			VAR MaxInc =
			    MAXX(TablaResumen, [Inc])
			RETURN
			    CONCATENATEX(
			        FILTER(TablaResumen, [Inc] = MaxInc),
			        dim_municipios[Subregion],
			        ", "
			    )
			
			```

		displayFolder: "IPM"

		lineageTag: 055cb1e5-0eb7-4c20-bd17-c0889cbd354a

	measure Participacion_IPM_Grupo = ```
			
			DIVIDE(
			    [Personas IPM],
			    CALCULATE(
			        [Personas IPM],
			        ALLEXCEPT(dim_municipios, dim_municipios[Subregion])
			    )
			)
			
			```

		displayFolder: "IPM"

		lineageTag: 5c7ec9aa-3388-4fb2-ae85-ecd17de6a16b

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Participacion_IPM_Subregion2 = ```
			
			DIVIDE(
			    [Personas IPM],
			    CALCULATE(
			        [Personas IPM],
			        ALLEXCEPT(dim_municipios, dim_municipios[Subregion]),
