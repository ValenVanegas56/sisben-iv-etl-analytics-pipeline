	measure 'Personas IPM' =
			
			CALCULATE(
			    COUNTROWS(fct_Sisben),
			    LEFT(TRIM(fct_Sisben[H_5]),1) = "1"
			)
		formatString: #,0

		displayFolder: "IPM"

		lineageTag: 12a830d5-cc35-431d-bd42-29e44828c82c

	measure Porcentaje_IPM =
			
			DIVIDE([Personas IPM], [Personas], 0)
