	measure Año_Maximo =
			
			MAX(fct_Sisben[anio])
		formatString: 0

		displayFolder: "IPM"

		lineageTag: ebe85ced-2bb3-4e11-b4ec-f2bc3cfe2bd4

	measure IPM_Año_Actual = ```
			
			CALCULATE(
			    [Porcentaje_IPM],
			    FILTER(
			        ALL(fct_Sisben[anio]),
			        [anio] = MAX(fct_Sisben[anio])
			    )
			)
			
			```

		displayFolder: "IPM"

		lineageTag: f8153840-ac1e-4633-98ca-8dc0735f070d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure IPM_Año_Anterior = ```
			
			CALCULATE(
			    [Porcentaje_IPM],
			    FILTER(
			        ALL(fct_Sisben[anio]),
			        [anio] = MAX([anio]) - 1
			    )
			)
			
			```

		displayFolder: "IPM"

		lineageTag: 24abd36a-fa2a-4eff-84c3-a13751678c51

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Variacion_IPM = ```
			
			[IPM_Año_Actual] - [IPM_Año_Anterior]
			
			```

		displayFolder: "IPM"

		lineageTag: 27ede75a-9a87-4ab4-a3e1-26e8d6e5b12d

