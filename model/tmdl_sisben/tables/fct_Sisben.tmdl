	measure 'Tasa de Cobertura SisbÃ©n' =
			VAR current_year = MAX(fct_Sisben[anio])
			VAR personas_sisben = [Personas]
			VAR pob_dane = CALCULATE(
			    SUM('Poblacion_DANE'[Poblacion_Proyectada]),
			    TREATAS({current_year}, 'Dim_Anios'[anio])
			)
			RETURN DIVIDE(personas_sisben, pob_dane)
		formatString: 0.00%

		displayFolder: "Demografia"

		lineageTag: a7e007ca-46aa-4fd5-91bf-d2b8001d0fb2

	measure UX_Titulo_Tablero = ```
			
			-- 1. Bloque Tiempo
			VAR vAno = IF(ISFILTERED(fct_Sisben[anio]), "Año " & CONCATENATEX(VALUES(fct_Sisben[anio]), fct_Sisben[anio], ", "), BLANK())
			
			-- 2. Bloque Geografía (Subregión con tildes y formato correcto)
			VAR tSubRaw = IF(ISFILTERED('dim_municipios'[Subregion]), SELECTEDVALUE('dim_municipios'[Subregion]), BLANK())
			VAR tSub = IF(ISBLANK(tSubRaw), BLANK(), 
			              "En " & SWITCH(tSubRaw, 
			                  "VALLE DE ABURRA", "Valle de Aburra", 
			                  "BAJO CAUCA", "Bajo Cauca", 
			                  "MAGDALENA MEDIO", "Magdalena Medio", 
			                  "NORDESTE", "Nordeste", 
			                  "NORTE", "Norte", 
			                  "OCCIDENTE", "Occidente", 
			                  "ORIENTE", "Oriente", 
			                  "SUROESTE", "Suroeste", 
			                  "URABA", "Uraba", 
			                  tSubRaw) -- Por si acaso hay una nueva
			          )
			
			VAR tMpio = IF(ISFILTERED('dim_municipios'[Municipio]), CONCATENATEX(VALUES('dim_municipios'[Municipio]), 'dim_municipios'[Municipio], ", "), BLANK())
			VAR vGeo = IF(ISBLANK(tSub), tMpio, tSub & IF(ISBLANK(tMpio), "", ", " & tMpio))
			
			-- 3. Bloque Zona (Ahora separado por punto medio)
			VAR vZona = IF(ISFILTERED(fct_Sisben[Zona]), "Zona " & CONCATENATEX(VALUES(fct_Sisben[Zona]), fct_Sisben[Zona], ", "), BLANK())
			
			-- 4. Bloque Sisbén (Grupo A, Clasificación)
			VAR tGrupo = IF(ISFILTERED(fct_Sisben[grupo_sisben]), "Grupo " & CONCATENATEX(VALUES(fct_Sisben[grupo_sisben]), fct_Sisben[grupo_sisben], ", "), BLANK())
			VAR tClasifica = IF(ISFILTERED(fct_Sisben[Clasificacion]), CONCATENATEX(VALUES(fct_Sisben[Clasificacion]), fct_Sisben[Clasificacion], ", "), BLANK())
			VAR vSisben = IF(ISBLANK(tGrupo), tClasifica, tGrupo & IF(ISBLANK(tClasifica), "", ", " & tClasifica))
			
			-- 5. Bloque Sexo (Agregando " Hogar" al final de Hombre Jefe / Mujer Jefe)
			VAR vSexo = IF(ISFILTERED(fct_Sisben[Sexo_Jefe_Label]), 
			               CONCATENATEX(VALUES(fct_Sisben[Sexo_Jefe_Label]), fct_Sisben[Sexo_Jefe_Label] & " Hogar", ", "), BLANK())
			
			-- 6. Bloque Edad
			VAR vMinE = MIN(fct_Sisben[Edad])
			VAR vMaxE = MAX(fct_Sisben[Edad])
			VAR vEdad = IF(ISFILTERED(fct_Sisben[Edad]), "Edades " & vMinE & " - " & vMaxE, BLANK())
			
			-- UNIÓN FINAL (Filtramos vacíos y unimos con punto medio)
			VAR unidos = 
			    CONCATENATEX(
			        FILTER( {vAno, vGeo, vZona, vSisben, vSexo, vEdad}, [Value] <> BLANK() ),
			        [Value],
			        " • "
			    )
			
			RETURN 
			    IF(ISBLANK(unidos), "Visión General: Departamento de Antioquia", "Selección de Filtros: " & unidos)
			
			```

		displayFolder: "UX"

		lineageTag: 5895de7b-e1b9-44c8-9f79-cdee35473e5c

