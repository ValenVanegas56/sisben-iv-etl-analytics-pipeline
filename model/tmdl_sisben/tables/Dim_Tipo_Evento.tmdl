			VAR _evento = SELECTEDVALUE(Dim_Tipo_Evento[TipoEvento])
			RETURN
			SWITCH(
			    _evento,
			    "InundaciÃ³n",   CALCULATE(AVERAGE(fct_Sisben[num_evento_inundacion]), fct_Sisben[ind_evento_inundacion] = 1),
			    "Avalancha",    CALCULATE(AVERAGE(fct_Sisben[num_evento_avalancha]),  fct_Sisben[ind_evento_avalancha] = 1),
			    "Terremoto",    CALCULATE(AVERAGE(fct_Sisben[num_evento_terremoto]),  fct_Sisben[ind_evento_terremoto] = 1),
